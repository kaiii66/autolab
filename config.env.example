# === Research project ===
# Git URL of the research repo to clone
RESEARCH_REPO="https://github.com/karpathy/autoresearch.git"

# Local directory name after cloning (defaults to repo name)
# RESEARCH_DIR="autoresearch"

# SkyPilot experiment template — URL or local path
# If unset, a generic template is created automatically.
SKYPILOT_TEMPLATE="https://raw.githubusercontent.com/skypilot-org/skypilot/master/examples/autoresearch/experiment.yaml"

# Files to copy into per-experiment workdirs (space-separated, relative to RESEARCH_DIR)
# These are the files the agent will snapshot when launching parallel experiments.
# Example: "train.py prepare.py pyproject.toml"
WORKDIR_FILES=""

# === W&B / Weave ===
# WANDB_API_KEY="your-key"      # or export before running setup.sh
# WANDB_ENTITY="your-entity"     # W&B team/user (passed as WANDB_ENTITY env var)
# WANDB_PROJECT="project-name"   # W&B project name only — no slashes
# WEAVE_PROJECT="entity/project" # Weave accepts entity/project format

# === Infrastructure ===
# Max parallel clusters (default: 4)
# MAX_CLUSTERS=4
